# ─────────────────────────────────────────────────────────────
# Root .gitignore — Acharya Ways
# ─────────────────────────────────────────────────────────────

# ── Environment variables (NEVER commit these!) ───────────────
**/.env
**/.env.local
**/.env.production
**/.env.*.local

# ── Node ──────────────────────────────────────────────────────
**/node_modules/
**/.npm
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# ── Next.js ───────────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/.vercel/

# ── Prisma / SQLite ───────────────────────────────────────────
backend/prisma/dev.db
backend/prisma/dev.db-journal
backend/prisma/*.db-shm
backend/prisma/*.db-wal

# ── Uploads ───────────────────────────────────────────────────
backend/uploads/

# ── OS / IDE ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
